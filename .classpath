<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="src" path="src"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-android-classes-javadoc.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-android-classes-sources.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-android-classes.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-classes-javadoc.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-classes-sources.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-classes-tests.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-classes.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-cmd-classes-javadoc.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-cmd-classes-sources.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-cmd-classes.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-summaries-classes-javadoc.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-summaries-classes-test-sources.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-summaries-classes.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-summaries-jar-with-dependencies.jar"/>
	<classpathentry kind="lib" path="Dependencies/soot-infoflow-cmd-jar-with-dependencies.jar"/>
	<classpathentry kind="output" path="out/production/IterativeFlowDroid"/>
</classpath>
